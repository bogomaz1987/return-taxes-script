# GitHub Personal Access Token (classic with the `repo` scope, or a fine-grained
# token with read access to the target repository).
#
# The SAME token is used both to list PRs and to download each PR's diff — no
# browser login is performed. If your repository belongs to an organization that
# enforces SSO, authorize the token for that organization:
#   Settings → Developer settings → Tokens → your token → "Configure SSO" → Authorize.
GITHUB_TOKEN=ghp_xxx

# Repository to scan, as "owner/name", and the PR author's GitHub login.
REPO=owner/repo
AUTHOR=your-github-username

# Tax logic: a working day is 8 hours, and 80% of the time is refundable.
# REFUND_PERCENT is a whole number 0-100 (e.g. 80 means 80%).
REFUND_PERCENT=80
WORK_HOURS_PER_DAY=8

# Where to store screenshots and the CSV (a YYYY-MM subfolder is created inside).
# Can be a relative or an absolute path, e.g. a OneDrive folder:
#   OUTPUT_DIR=/Users/you/Library/CloudStorage/OneDrive-Personal/tax
OUTPUT_DIR=screenshots

# true -> headless browser (default; no login is needed anyway).
HEADLESS=true
